flowchart TD
    subgraph Detection["Semantic Shift Detection"]
        direction TB
        CURR["Current user_msg<br/>e.g. 'what about the memory pipeline?'"]
        PREV["Previous user_msg<br/>e.g. 'how do I deploy to prod?'"]
        TOKEN["Tokenize both<br/>split_whitespace()<br/>trim non-alphanumeric<br/>filter len > 2"]
        OVERLAP["Calculate overlap<br/>|intersection| / max(|A|, |B|)"]
        THRESH{"overlap < 0.3?"}
        SHIFT["Semantic shift = TRUE"]
        CONT["Semantic shift = FALSE"]
    end

    subgraph EventStore["Event Storage (SQLite)"]
        direction TB
        EVT["events table<br/>id: UUID<br/>turn_index: INTEGER<br/>session_id: TEXT<br/>user_message: TEXT<br/>assistant_message: TEXT<br/>semantic_shift_detected: BOOLEAN<br/>created_at: TEXT"]
    end

    subgraph EpisodeStore["Episode Storage (SQLite)"]
        direction TB
        EP["episodes table<br/>id: UUID<br/>content: TEXT<br/>type: TEXT<br/>confidence: REAL<br/>importance: REAL<br/>compression_level: TEXT<br/>schema_section: TEXT<br/>session_id: TEXT<br/>created_at: TEXT"]
    end

    subgraph ContradictionStore["Contradiction Storage"]
        direction TB
        CT["contradictions table<br/>id: UUID<br/>existing_episode_id: TEXT FK<br/>existing_content: TEXT<br/>new_evidence_content: TEXT<br/>status: 'contested' | 'resolved'<br/>pressure_score: INTEGER<br/>importance: REAL<br/>created_at: TEXT"]
    end

    subgraph Relationships["How They Connect"]
        direction LR
        REL1["Events are RAW turns<br/>One per user+assistant exchange"]
        REL2["Episodes are EXTRACTED facts<br/>Derived from events via pipeline"]
        REL3["Contradictions link episodes<br/>old_episode ←→ new_evidence"]
        REL4["Gaps are episodes with<br/>type = 'gap'"]
    end

    CURR --> TOKEN
    PREV --> TOKEN
    TOKEN --> OVERLAP
    OVERLAP --> THRESH
    THRESH -->|yes| SHIFT
    THRESH -->|no| CONT
    
    SHIFT --> EVT
    CONT --> EVT
    
    EVT --> REL1
    EP --> REL2
    CT --> REL3
    
    REL1 --> REL2
    REL2 --> REL3
    REL2 --> REL4
    
    style Detection fill:#fff8e1
    style EventStore fill:#e3f2fd
    style EpisodeStore fill:#e8f5e9
    style ContradictionStore fill:#fce4ec
    style Relationships fill:#f3e5f5
