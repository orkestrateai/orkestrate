{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orkestrate",
  "version": "0.2.5",
  "identifier": "com.orkestrate.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "orkestrate",
        "width": 1280,
        "height": 800,
        "theme": "Dark",
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://orkestrate.space http://127.0.0.1:* ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["orkestrate"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/system1970/Orkestrate/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyRTkzNUQyQzE2NEFDQzkKUldUSnJHVEIwalhwTW5GN0M2S1diQURJSzg4SjNlc1lqU1QvUnZQS0g4NlFRQXdiVUl2c3lzRncK"
    }
  }
}
